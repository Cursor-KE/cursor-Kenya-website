# Copy to .env and adjust. Do not commit .env.

# Grafana (required for first login)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me-grafana-admin

# Optional: public URL if you reverse-proxy Grafana (e.g. https://grafana.example.com)
# GF_SERVER_ROOT_URL=

# Host port for Grafana UI (default 3000)
GRAFANA_HTTP_PORT=3000

# Pi-hole admin API — same value as WEBPASSWORD in compose/pihole/.env
# If you use Pi-hole’s API token instead, paste it here (see pihole-exporter docs).
PIHOLE_PASSWORD=change-me-same-as-pihole-webpassword

# Pi-hole web UI port on the host (Compose maps 8080:80 in the Pi-hole guide)
PIHOLE_API_PORT=8080

# Nextcloud base URL reachable from this stack (host.docker.internal matches nextcloud/.env trusted_domains)
NEXTCLOUD_SERVER=http://host.docker.internal:8081

# Preferred: Nextcloud 22+ serverinfo token (see README.md in this folder)
NEXTCLOUD_AUTH_TOKEN=

# Alternative: admin or dedicated user + app password (leave token empty)
NEXTCLOUD_USERNAME=
NEXTCLOUD_PASSWORD=
